# ═══════════════════════════════════════
# DeepShield — Environment Configuration
# ═══════════════════════════════════════
# Copy this file to backend/.env and customize

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]

# Database
# For local dev: sqlite:///./deepshield.db
# For production (Neon/Supabase): postgresql://username:password@ep-cool...
DATABASE_URL=sqlite:///./deepshield.db

# File Upload
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=./temp_uploads
FILE_RETENTION_SECONDS=300

# AI Models
IMAGE_MODEL_ID=prithivMLmods/Deep-Fake-Detector-v2-Model
TEXT_MODEL_ID=jy46604790/Fake-News-Bert-Detect
# Phase 13: multilingual text model — any HF text-classification model fine-tuned on multilingual
# fake-news data (e.g. xlm-roberta-base fine-tuned on LIAR). Leave empty to fall back to TEXT_MODEL_ID.
TEXT_MULTILANG_MODEL_ID=
# OCR languages (comma-separated). Default: en,hi (English + Hindi)
OCR_LANGS=en,hi
DEVICE=cpu
PRELOAD_MODELS=true

# News API (optional — sign up at https://newsdata.io)
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsdata.io/api/1/news

# PDF Reports
REPORT_DIR=./temp_reports
REPORT_TTL_SECONDS=3600

# LLM Explainability (Phase 12 — optional, gracefully degrades if absent)
# Supported providers: "gemini" or "openai"
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL=gemini-1.5-flash

# ── EfficientNet (ICPR2020 / DeepShield1 merge) ──────────────────────────────
# Model name and training dataset. Supported: EfficientNetAutoAttB4_DFDC (default)
EFFICIENTNET_MODEL=EfficientNetAutoAttB4
EFFICIENTNET_TRAIN_DB=DFDC
# ENSEMBLE_MODE=true  → run both ViT + EfficientNet and average scores (recommended)
# ENSEMBLE_MODE=false → ViT-only fallback (set false to disable EfficientNet entirely)
ENSEMBLE_MODE=true
# Frames to sample per video for EfficientNet inference
VIDEO_SAMPLE_FRAMES=16
# (Optional) ExifTool CLI path for writing verdict into analyzed file metadata.
# Leave empty to skip metadata embedding. Install ExifTool and set full path:
# Windows: C:\Windows\exiftool.exe  |  Linux/Mac: /usr/bin/exiftool
EXIFTOOL_PATH=
# (Optional) Override torch model cache location. Useful if C: is tight (~75MB for EfficientNet weights).
# TORCH_HOME=D:\torch_cache

# Auth — CHANGE JWT_SECRET_KEY IN PRODUCTION!
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
